# Lokal test qilish uchun shu faylni .env deb nomlang va haqiqiy qiymatlar bilan to'ldiring.
# Render'da bular kerak emas - Render Dashboard > Environment bo'limiga yozasiz.

# ============================================================
# Telegram
# ============================================================
TOKEN=123456789:AAExampleTelegramBotTokenHere
ADMIN_ID=123456789
# Doimiy ma'lumotlar (pul/olmos/statistika/shop) saqlanadigan yopiq supergroup ID.
# Bot shu guruhda admin bo'lishi kerak (pin, edit, delete, invite huquqlari bilan):
DB_CHAT_ID=-1001234567890
SKIP_PENDING=false

# ============================================================
# O'yin sozlamalari (ixtiyoriy - berilmasa standart qiymat ishlatiladi)
# ============================================================
PLAYERS_COUNT_TO_START=4
PLAYERS_COUNT_LIMIT=10
REQUEST_OVERDUE_TIME=600
WORD_BASE=words.txt
DELETE_FROM_EVERYONE=false

# ============================================================
# Server / Webhook (Render Web Service)
# ============================================================
SET_WEBHOOK=true
# Render RENDER_EXTERNAL_URL'ni avtomatik beradi - odatda quyidagini yozish shart
# emas. Lokal test qilsangiz (masalan ngrok) shu yerga public HTTPS manzil yozing:
WEBHOOK_URL=https://your-app-name.onrender.com
# Render PORT'ni avtomatik beradi:
PORT=8080

LOGGER_LEVEL=INFO
